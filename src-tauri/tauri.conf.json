{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "rdm",
  "version": "0.1.0",
  "identifier": "com.rdm.gui",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "rdm 下载管理器",
        "width": 960,
        "height": 640,
        "resizable": true,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
