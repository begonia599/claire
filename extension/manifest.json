{
  "manifest_version": 3,
  "name": "rdm 接管",
  "version": "0.1.0",
  "description": "把浏览器下载接管给 rdm 下载管理器（多线程分段 + 断点续传）",
  "permissions": ["downloads", "contextMenus", "storage", "notifications"],
  "host_permissions": ["http://127.0.0.1:7319/*"],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "rdm 接管" },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
